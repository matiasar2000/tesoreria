# Langfuse v3 local self-hosting configuration.
# Copy to .env.langfuse and replace every value marked with CHANGE_ME.
#
# Secret generation examples:
# - NEXTAUTH_SECRET / SALT: openssl rand -base64 32
# - ENCRYPTION_KEY: openssl rand -hex 32

NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
SALT=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_LANGFUSE_POSTGRES_PASSWORD
POSTGRES_DB=postgres

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGE_ME_LANGFUSE_CLICKHOUSE_PASSWORD

REDIS_AUTH=CHANGE_ME_LANGFUSE_REDIS_PASSWORD

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME_LANGFUSE_MINIO_PASSWORD

# Optional headless bootstrap. Leave empty to create org/project/user in UI.
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=Tesoreria Local
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=Tesoreria IA Local
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false
